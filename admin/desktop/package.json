{
  "name": "michael-demsko-site-admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.michaeldemskojr.siteadmin",
    "productName": "Michael Demsko Site Admin",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.svg"
    }
  }
}
