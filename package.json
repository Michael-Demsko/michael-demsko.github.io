{
  "name": "michael-demsko.github.io-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "website",
    "admin/desktop"
  ],
  "scripts": {
    "dev:website": "npm --workspace website run dev",
